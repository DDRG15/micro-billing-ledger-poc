# .env.example — Micro-Billing-Ledger
# =====================================
# Copia este archivo a .env y llena los valores de producción.
# El .env NUNCA se sube a git — está en .gitignore.
#
# Para desarrollo local: los valores de abajo funcionan sin cambios.
# Para producción: cambia TODOS los valores marcados con *** CAMBIAR ***.
#
# Copy this file to .env and fill in production values.
# The .env file is NEVER committed — it's in .gitignore.
#
# For local dev: the values below work as-is.
# For production: change ALL values marked with *** CHANGE ***.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# *** CAMBIAR EN PRODUCCIÓN / CHANGE IN PRODUCTION ***
# Usa: openssl rand -hex 32
# Use: openssl rand -hex 32

POSTGRES_DB=billing

# URL completa — debe coincidir con POSTGRES_USER/PASSWORD/DB arriba.
# Full URL — must match POSTGRES_USER/PASSWORD/DB above.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/billing
# *** CAMBIAR EN PRODUCCIÓN: postgresql://postgres:TU_PASSWORD@postgres:5432/billing ***
# *** CHANGE IN PRODUCTION:  postgresql://postgres:YOUR_PASSWORD@postgres:5432/billing ***

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE
# *** CAMBIAR / CHANGE ***
# Stripe Dashboard → Developers → Webhooks → Signing secret
# Formato / Format: whsec_xxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Billing API Key — protege los endpoints /dlq y /ledger/summary
# Billing API Key — protects the /dlq and /ledger/summary endpoints
# ---------------------------------------------------------------------------
BILLING_API_KEY=dev_key_change_in_production
# *** CAMBIAR EN PRODUCCIÓN / CHANGE IN PRODUCTION ***
# Usa: openssl rand -hex 32
# Use: openssl rand -hex 32
# Deja vacío para deshabilitar auth (solo desarrollo).
# Leave empty to disable auth (dev only).

# ---------------------------------------------------------------------------
# Worker — Outbox drain
# ---------------------------------------------------------------------------
DOWNSTREAM_URL=
# *** CAMBIAR EN PRODUCCIÓN / CHANGE IN PRODUCTION ***
# URL del sistema downstream que recibe los eventos.
# URL of the downstream system that receives events.
# Ejemplo / Example: https://analytics.internal/billing-events
# Dejar vacío + WORKER_LOG_ONLY=true → modo log-only (no reenvía).
# Leave empty + WORKER_LOG_ONLY=true → log-only mode (no forwarding).

WORKER_LOG_ONLY=true
# *** CAMBIAR EN PRODUCCIÓN: WORKER_LOG_ONLY=false ***
# Requiere DOWNSTREAM_URL configurado. Sin él el worker no arranca.
# Requires DOWNSTREAM_URL set. Without it the worker won't start.

WORKER_BATCH_SIZE=100
WORKER_POLL_INTERVAL=5

# ---------------------------------------------------------------------------
# Caddy — HTTPS / TLS automático
# Caddy — automatic HTTPS / TLS
# ---------------------------------------------------------------------------
CADDY_DOMAIN=localhost
# *** CAMBIAR EN PRODUCCIÓN / CHANGE IN PRODUCTION ***
# Tu dominio real apuntando a este servidor.
# Your real domain pointing to this server.
# Ejemplo / Example: billing.tuempresa.com
#
# Cuando pones un dominio real y el puerto 443 está abierto,
# Caddy obtiene el certificado de Let's Encrypt automáticamente.
# No necesitas hacer nada más para tener HTTPS.
#
# When you set a real domain and port 443 is open,
# Caddy obtains the Let's Encrypt certificate automatically.
# You don't need to do anything else to get HTTPS.

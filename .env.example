# .env.example — Micro-Billing-Ledger
# =====================================
# Copy this file to .env and fill in production values.
# The .env file is NEVER committed — it is in .gitignore.
#
# For local dev: the values below work as-is.
# For production: change ALL values marked with *** CHANGE ***.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# *** CHANGE IN PRODUCTION ***
# Use: openssl rand -hex 32

POSTGRES_DB=billing

# Full URL — must match POSTGRES_USER/PASSWORD/DB above.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/billing
# *** CHANGE IN PRODUCTION: postgresql://postgres:YOUR_PASSWORD@postgres:5432/billing ***

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE
# *** CHANGE ***
# Stripe Dashboard → Developers → Webhooks → Signing secret
# Format: whsec_xxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Billing API Key — protects the /dlq and /ledger/summary endpoints
# ---------------------------------------------------------------------------
BILLING_API_KEY=dev_key_change_in_production
# *** CHANGE IN PRODUCTION ***
# Use: openssl rand -hex 32
# Leave empty to disable auth (dev only).

# ---------------------------------------------------------------------------
# Worker — Outbox drain
# ---------------------------------------------------------------------------
DOWNSTREAM_URL=
# *** CHANGE IN PRODUCTION ***
# URL of the downstream system that receives events.
# Example: https://analytics.internal/billing-events
# Leave empty + WORKER_LOG_ONLY=true → log-only mode (no forwarding).

WORKER_LOG_ONLY=true
# *** CHANGE IN PRODUCTION: WORKER_LOG_ONLY=false ***
# Requires DOWNSTREAM_URL set. Without it the worker will not start.

WORKER_BATCH_SIZE=100
WORKER_POLL_INTERVAL=5

# ---------------------------------------------------------------------------
# Caddy — automatic HTTPS / TLS
# ---------------------------------------------------------------------------
CADDY_DOMAIN=localhost
# *** CHANGE IN PRODUCTION ***
# Your real domain pointing to this server.
# Example: billing.yourcompany.com
#
# When you set a real domain and port 443 is open,
# Caddy obtains the Let's Encrypt certificate automatically.
# You do not need to do anything else to get HTTPS.

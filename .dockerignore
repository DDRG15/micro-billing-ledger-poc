# .dockerignore — Micro-Billing-Ledger PoC
# ==========================================
# Excludes files from the Docker build context.
#     A smaller context = faster builds and no accidental secret leaks into images.
#     Rule: only source code and package manifests belong inside the image.
#

# Git history — never include in the image. Large, irrelevant to runtime, and leaks commit metadata.
.git/
.gitignore

# Secrets — critical exclusion. .env must NEVER enter a Docker image.
#     If an image with .env is pushed to a registry, the secret is compromised.
#     .env.example is also excluded — it contains placeholder values, not needed at runtime.
.env
.env.example
.env.local
.env.production

# Python bytecode and virtual environments — machine-specific, rebuilt inside the container.
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
*.egg-info/

# Test suite and audit/planning documents — not needed at runtime.
test_ledger.py
PREFLIGHT_AUDIT.md
FULL_SPECTRUM_AUDIT.md
PRIVATE_README.md
LOGIC_AUDIT.md
IMPLEMENTATION_REPORT.md
README.md
*.md

# Development toolchain config and cache.
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Log files — runtime artefacts, not source. Could contain PII.
*.log

# OS noise.
.DS_Store
Thumbs.db

# Claude Code workspace files — local AI assistant state, not part of the app.
.claude/

# Caddyfile — Micro-Billing-Ledger reverse proxy + TLS
# ======================================================
# Caddy automatically obtains and renews a TLS certificate from
#     Let's Encrypt when CADDY_DOMAIN is set to a real domain and
#     port 443 is reachable from the internet.
#
#     To activate HTTPS in production:
#       1. Point your domain DNS to this server's IP.
#       2. Open port 443 on your firewall / security group.
#       3. Set CADDY_DOMAIN=billing.yourcompany.com in your .env file.
#       4. Run: docker-compose up -d
#       Caddy does the rest — no certbot, no cron, no manual renewal.
#
# LOCAL DEV:
#   With CADDY_DOMAIN=localhost (default in .env.example), Caddy uses
#   a self-signed certificate. Your browser will show a security warning —
#   this is expected for localhost. For local dev you can also access
#   the API directly on http://localhost:8000 (billing port is still exposed).

{$CADDY_DOMAIN} {
    # Forward all traffic to the billing FastAPI container.
    #     The billing service is NOT exposed to the internet directly —
    #     all external traffic must pass through Caddy.
    reverse_proxy billing:8000

    # Security headers — applied to every response.
    header {
        # Prevent clickjacking
        X-Frame-Options DENY
        # Prevent MIME type sniffing
        X-Content-Type-Options nosniff
        # Enable HSTS (tell browsers to always use HTTPS for this domain)
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Remove server fingerprint
        -Server
    }
}

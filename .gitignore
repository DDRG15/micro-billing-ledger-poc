# .gitignore — Micro-Billing-Ledger PoC
# ========================================
# Files and directories that should never be committed to git.
#     Rule of thumb: if it contains secrets, is auto-generated, or is machine-specific,
#     it does not belong in the repository.

# Python bytecode cache — auto-generated by the interpreter on first import.
#     Different Python versions generate different bytecode; committing it causes conflicts.
__pycache__/
*.pyc
*.pyo

# SQLite database files — these are runtime data, not source code.
#     billing_ledger.db is created automatically on first run by _bootstrap().
#     The WAL and SHM sidecar files are SQLite's write-ahead log and shared memory files.
#     None of these should be in version control — they contain live transaction data.
*.db
*.db-wal
*.db-shm

# Python virtual environments — machine-specific paths, never portable across systems.
#     The correct approach: share requirements.txt and let each dev create their own venv.
venv/
.venv/
env/

# Environment variables file — THIS IS A SECURITY CRITICAL EXCLUSION.
#     .env contains STRIPE_WEBHOOK_SECRET and any other secrets.
#     If this file is ever committed, rotate ALL secrets immediately — git history is public.
.env
.env.local
.env.production

# Log files — auto-generated at runtime by the logging handlers in ledger.py.
#     billing_ledger.log contains raw payloads from DLQ write failures (ERROR level).
#     These can be large and contain PII — never commit them.
*.log

# pytest cache — auto-generated by pytest on first run.
.pytest_cache/

# Python packaging artifacts — only relevant if publishing to PyPI.
*.egg-info/
dist/
build/
*.whl

# mypy type-check cache.
.mypy_cache/

# OS-specific metadata files — created by macOS Finder, Windows Explorer, etc.
#     Pure noise in a git repository.
.DS_Store
Thumbs.db

# Claude Code workspace — tool-specific state, plans, and memory. Not app code.
.claude/

# Local-only notes — personal working documents that stay on this machine.
BUG_REPORT.md
ROADMAP.md
TONE_ANALYSIS.md
PRIVATE_README.md
FULL_SPECTRUM_AUDIT.md
IMPLEMENTATION_REPORT.md
LOGIC_AUDIT.md
PREFLIGHT_AUDIT.md
TOMORROW.md
